export component AppWindow inherits Window {
    in-out property <string> time-text: "00:00";
    in-out property <string> seconds-text: "00";
    in-out property <string> date-text: "0000年00月00日";
    in-out property <string> weekday-text: "星期一";
    in-out property <string> year-remaining-text: "今年还剩 0%";
    in-out property <float> year-remaining-progress: 0.0;
    in-out property <string> cpa-countdown-text: "还有 0 天";
    in-out property <string> cpa-date-text: "考试日期 · 8月29日";
    in-out property <string> quote-english: "Small steps still move you forward.";
    in-out property <string> quote-chinese: "每一个微小的行动，都在让你靠近目标。";
    in-out property <image> background-image;
    in-out property <bool> has-background-image: false;
    in-out property <bool> night-mode: false;

    callback screen-tapped();

    preferred-width: 800px;
    preferred-height: 480px;
    background: root.night-mode ? #111817 : #2d3934;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.night-mode ? #111817 : #2d3934;

        if root.has-background-image: Image {
            width: parent.width;
            height: parent.height;
            source: root.background-image;
            image-fit: cover;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: root.night-mode
                ? @linear-gradient(90deg, #0b1110ee 0%, #0d1412b8 62%, #0d14128c 100%)
                : @linear-gradient(90deg, #15201ddb 0%, #18241fa0 62%, #18241f72 100%);
        }

        Rectangle {
            x: 0;
            y: parent.height - 150px;
            width: parent.width;
            height: 150px;
            background: @linear-gradient(0deg, #080d0ccb 0%, #080d0c00 100%);
        }

        Text {
            x: 58px;
            y: 54px;
            width: 400px;
            height: 122px;
            text: root.time-text;
            color: #f8f5ee;
            font-family: "Noto Serif CJK SC";
            font-size: 118px;
            font-weight: 400;
            vertical-alignment: center;
        }

        Text {
            x: 424px;
            y: 91px;
            width: 46px;
            height: 40px;
            text: root.seconds-text;
            color: #f8f5ee99;
            font-family: "Noto Serif CJK SC";
            font-size: 27px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: 64px;
            y: 192px;
            width: 300px;
            height: 30px;
            text: root.date-text;
            color: #f8f5eed4;
            font-family: "WenQuanYi Zen Hei";
            font-size: 22px;
            vertical-alignment: center;
        }

        Text {
            x: 64px;
            y: 224px;
            width: 160px;
            height: 26px;
            text: root.weekday-text;
            color: #f8f5ee9e;
            font-family: "WenQuanYi Zen Hei";
            font-size: 17px;
            vertical-alignment: center;
        }

        Rectangle {
            x: parent.width - 268px;
            y: 42px;
            width: 210px;
            height: 112px;
            border-radius: 18px;
            background: #121a18a8;
            border-color: #ffffff22;
            border-width: 1px;

            Text {
                x: 18px;
                y: 14px;
                width: parent.width - 36px;
                height: 24px;
                text: "年度倒计时";
                color: #f8f5ee99;
                font-family: "WenQuanYi Zen Hei";
                font-size: 17px;
            }

            Text {
                x: 18px;
                y: 41px;
                width: parent.width - 36px;
                height: 35px;
                text: root.year-remaining-text;
                color: #f8f5ee;
                font-family: "WenQuanYi Zen Hei";
                font-size: 23px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Rectangle {
                x: 18px;
                y: 92px;
                width: parent.width - 36px;
                height: 4px;
                border-radius: 2px;
                background: #ffffff26;
            }

            Rectangle {
                x: 18px;
                y: 92px;
                width: (parent.width - 36px) * root.year-remaining-progress;
                height: 4px;
                border-radius: 2px;
                background: #dbc99f;
            }
        }

        Rectangle {
            x: parent.width - 268px;
            y: 166px;
            width: 210px;
            height: 116px;
            border-radius: 18px;
            background: #121a18a8;
            border-color: #ffffff22;
            border-width: 1px;

            Text {
                x: 18px;
                y: 12px;
                width: parent.width - 36px;
                height: 25px;
                text: "CPA 考试倒计时";
                color: #f8f5ee99;
                font-family: "WenQuanYi Zen Hei";
                font-size: 17px;
            }

            Text {
                x: 18px;
                y: 39px;
                width: parent.width - 36px;
                height: 38px;
                text: root.cpa-countdown-text;
                color: #f8f5ee;
                font-family: "WenQuanYi Zen Hei";
                font-size: 25px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                x: 18px;
                y: 82px;
                width: parent.width - 36px;
                height: 24px;
                text: root.cpa-date-text;
                color: #f8f5ee85;
                font-family: "WenQuanYi Zen Hei";
                font-size: 16px;
            }
        }

        Text {
            x: 64px;
            y: parent.height - 120px;
            width: parent.width - 128px;
            height: 48px;
            text: root.quote-english;
            color: #f8f5eef2;
            font-family: "Noto Serif CJK SC";
            font-size: 24px;
            font-weight: 400;
            vertical-alignment: bottom;
            wrap: word-wrap;
        }

        Text {
            x: 64px;
            y: parent.height - 70px;
            width: parent.width - 128px;
            height: 38px;
            text: root.quote-chinese;
            color: #f8f5eeb5;
            font-family: "WenQuanYi Zen Hei";
            font-size: 24px;
            vertical-alignment: top;
            wrap: word-wrap;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.screen-tapped();
            }
        }
    }
}
