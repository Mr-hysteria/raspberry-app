export component AppWindow inherits Window {
    in-out property <string> time-text: "00:00";
    in-out property <string> seconds-text: "00";
    in-out property <string> date-weekday-text: "0000年00月00日 · 星期一";
    in-out property <string> year-remaining-text: "今年还剩 0%";
    in-out property <float> year-remaining-progress: 0.0;
    in-out property <string> cpa-countdown-text: "还有 0 天";
    in-out property <string> cpa-date-text: "考试日期 · 8月29日";
    in-out property <string> quote-english: "Small steps still move you forward.";
    in-out property <string> quote-chinese: "每一个微小的行动，都在让你靠近目标。";
    in-out property <image> background-image;
    in-out property <bool> has-background-image: false;
    in-out property <bool> night-mode: false;

    callback screen-tapped();

    preferred-width: 800px;
    preferred-height: 480px;
    background: root.night-mode ? #111817 : #2d3934;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.night-mode ? #111817 : #2d3934;

        if root.has-background-image: Image {
            width: parent.width;
            height: parent.height;
            source: root.background-image;
            image-fit: cover;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: root.night-mode
                ? @linear-gradient(90deg, #0d1513df 0%, #0d1412bf 62%, #0a100fe0 100%)
                : @linear-gradient(90deg, #17231fcf 0%, #18241fa8 62%, #0c1311d0 100%);
        }

        Rectangle {
            x: 0;
            y: parent.height - 150px;
            width: parent.width;
            height: 160px;
            background: @linear-gradient(0deg, #070b0ae8 0%, #080d0c00 100%);
        }

        Text {
            x: 58px;
            y: 54px;
            width: 400px;
            height: 122px;
            text: root.time-text;
            color: #f8f5ee;
            font-family: "Noto Serif CJK SC";
            font-size: 118px;
            font-weight: 400;
            vertical-alignment: center;
        }

        Text {
            x: 430px;
            y: 72px;
            width: 42px;
            height: 34px;
            text: root.seconds-text;
            color: #f8f5ee75;
            font-family: "Noto Serif CJK SC";
            font-size: 23px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: 64px;
            y: 192px;
            width: 420px;
            height: 32px;
            text: root.date-weekday-text;
            color: #f8f5eee0;
            font-family: "WenQuanYi Zen Hei";
            font-size: 23px;
            font-weight: 500;
            vertical-alignment: center;
        }

        Rectangle {
            x: parent.width - 270px;
            y: 44px;
            width: 220px;
            height: 102px;
            border-radius: 18px;
            background: #080d0cdd;
            border-color: #ffffff38;
            border-width: 2px;

            Text {
                x: 20px;
                y: 14px;
                width: parent.width - 40px;
                height: 50px;
                text: root.year-remaining-text;
                color: #fffdf7;
                font-family: "WenQuanYi Zen Hei";
                font-size: 28px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                x: 20px;
                y: 78px;
                width: parent.width - 40px;
                height: 7px;
                border-radius: 4px;
                background: #ffffff38;
            }

            Rectangle {
                x: 20px;
                y: 78px;
                width: (parent.width - 40px) * root.year-remaining-progress;
                height: 7px;
                border-radius: 4px;
                background: #f1d899;
            }
        }

        Rectangle {
            x: parent.width - 270px;
            y: 158px;
            width: 220px;
            height: 112px;
            border-radius: 18px;
            background: #080d0cdd;
            border-color: #ffffff38;
            border-width: 2px;

            Text {
                x: 20px;
                y: 12px;
                width: parent.width - 40px;
                height: 49px;
                text: root.cpa-countdown-text;
                color: #fffdf7;
                font-family: "WenQuanYi Zen Hei";
                font-size: 28px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Text {
                x: 20px;
                y: 66px;
                width: parent.width - 40px;
                height: 28px;
                text: root.cpa-date-text;
                color: #f8f5eed0;
                font-family: "WenQuanYi Zen Hei";
                font-size: 18px;
                font-weight: 500;
            }
        }

        Text {
            x: 64px;
            y: parent.height - 126px;
            width: parent.width * 0.72;
            height: 54px;
            text: root.quote-english;
            color: #f8f5eef2;
            font-family: "Noto Serif CJK SC";
            font-size: 24px;
            font-weight: 400;
            vertical-alignment: bottom;
            wrap: word-wrap;
        }

        Text {
            x: 64px;
            y: parent.height - 66px;
            width: parent.width * 0.72;
            height: 34px;
            text: root.quote-chinese;
            color: #f8f5eeb5;
            font-family: "WenQuanYi Zen Hei";
            font-size: 21px;
            vertical-alignment: top;
            wrap: word-wrap;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.screen-tapped();
            }
        }
    }
}
